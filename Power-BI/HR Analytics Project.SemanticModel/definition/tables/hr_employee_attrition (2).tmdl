	column 'Age (bins)' =
			VAR __Count = 7
			
			VAR __Min = MIN('hr_employee_attrition (2)'[Age])
			
			VAR __Max = MAX('hr_employee_attrition (2)'[Age])
			
			VAR __Difference = (__Max - __Min)
			
			VAR __Size = IF(__Difference > 0, __Difference / __Count, 1)
			
			VAR __BinNumber = INT(('hr_employee_attrition (2)'[Age] - __Min) / __Size)
			
			RETURN
				IF(
					ISBLANK('hr_employee_attrition (2)'[Age]),
					BLANK(),
					__Min + (MIN(__BinNumber, __Count - 1) * __Size)
				)
		lineageTag: f9fc35bc-c507-4de4-a2c6-0c4670606e5e
		summarizeBy: none

		extendedProperty GroupingMetadata =
				{
